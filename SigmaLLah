local objIsLoading = false

local function OBJLoadIntoPreview(thenBuild)
    if objIsLoading then Notify("OBJ","Уже загружается...","warn"); return end
    if not OBJ_BLOCK_TEMPLATE then
        Notify("OBJ","Блок-шаблон не найден в BuildingParts!","error"); return
    end
    if not selectedOBJ then
        objStatus.Text = "⚠ Выбери .obj файл"
        Notify("OBJ","Выбери файл","warn"); return
    end

    local path = SAVE_FOLDER.."/"..selectedOBJ..".obj"
    local readOk, content = pcall(readfile, path)
    if not readOk then
        objStatus.Text = "✘ Ошибка чтения:\n"..tostring(content)
        Notify("OBJ","Ошибка чтения","error"); return
    end

    objIsLoading = true
    objStatus.Text = "⏳ Парсинг OBJ..."

    task.spawn(function()
        -- ── Парсинг ──────────────────────────────────────────
        local verts, vnorms, triangles = {}, {}, {}
        local lineN = 0
        for line in content:gmatch("[^\r\n]+") do
            lineN = lineN + 1
            if lineN % 2000 == 0 then
                objStatus.Text = "Парсинг... строка "..lineN; task.wait()
            end
            local p = {}
            for w in line:gmatch("%S+") do table.insert(p, w) end
            if #p == 0 or p[1]:sub(1,1) == "#" then continue end

            if p[1] == "v" and #p >= 4 then
                local x,y,z = tonumber(p[2]),tonumber(p[3]),tonumber(p[4])
                if x and y and z then table.insert(verts, Vector3.new(x,y,z)) end

            elseif p[1] == "vn" and #p >= 4 then
                local x,y,z = tonumber(p[2]),tonumber(p[3]),tonumber(p[4])
                if x and y and z then table.insert(vnorms, Vector3.new(x,y,z)) end

            elseif p[1] == "f" and #p >= 4 then
                local vi, ni = {}, {}
                for i = 2, #p do
                    local vI,_,nI = p[i]:match("^([%-%d]+)/?([%-%d]*)/?([%-%d]*)")
                    local v, n = tonumber(vI), tonumber(nI)
                    if v then
                        if v < 0 then v = #verts  + v + 1 end
                        if n and n < 0 then n = #vnorms + n + 1 end
                        table.insert(vi, v); table.insert(ni, n)
                    end
                end
                for i = 2, #vi-1 do
                    local a,b,c = vi[1],vi[i],vi[i+1]
                    local na,nb,nc = ni[1],ni[i],ni[i+1]
                    if verts[a] and verts[b] and verts[c] then
                        local avgN
                        if na and nb and nc and vnorms[na] and vnorms[nb] and vnorms[nc] then
                            avgN = (vnorms[na]+vnorms[nb]+vnorms[nc])/3
                        end
                        table.insert(triangles, {a,b,c,avgN})
                    end
                end
            end
        end

        local totalTris = #triangles
        objStatus.Text = string.format("✔ Найдено %d треуг. | %d вершин\nЦентрируем...", totalTris, #verts)
        task.wait()

        if totalTris == 0 then
            objStatus.Text = "✘ Нет треугольников!"
            Notify("OBJ","Нет треугольников в файле","error")
            objIsLoading = false; return
        end

        -- ── Bounding box → центр ─────────────────────────────
        local bMin = Vector3.new( math.huge, math.huge, math.huge)
        local bMax = Vector3.new(-math.huge,-math.huge,-math.huge)
        for _, v in ipairs(verts) do
            bMin = Vector3.new(math.min(bMin.X,v.X),math.min(bMin.Y,v.Y),math.min(bMin.Z,v.Z))
            bMax = Vector3.new(math.max(bMax.X,v.X),math.max(bMax.Y,v.Y),math.max(bMax.Z,v.Z))
        end
        local center = (bMin+bMax)*0.5

        -- ── Origin ───────────────────────────────────────────
        local zone = GetZone(selectedTeam)
        local originCF = (zone and zone.CFrame)
            or (LP.Character and LP.Character:GetPivot())
            or CFrame.new(0,5,0)

        -- ── Очищаем старый OBJ preview ───────────────────────
        for _, b in ipairs(objBlockList) do
            if b and b.Parent then b:Destroy() end
        end
        objBlockList = {}

        -- ── Рендер — все треугольники, только gap fill ────────
        local rendered = 0
        _hue = 0

        for triIdx = 1, totalTris do
            local tri = triangles[triIdx]
            local a,b,c = tri[1],tri[2],tri[3]
            local normHint = tri[4]

            local lp1 = (verts[a]-center)*OBJ_SCALE
            local lp2 = (verts[b]-center)*OBJ_SCALE
            local lp3 = (verts[c]-center)*OBJ_SCALE

            local faceN = normHint
            if not faceN then
                local cross = (lp2-lp1):Cross(lp3-lp1)
                local cL    = cross.Magnitude
                faceN = cL>1e-6 and cross/cL or Vector3.new(0,1,0)
            end

            local col = NextColor(OBJ_COLORMODE, faceN, triIdx, totalTris)

            local wp1 = originCF:PointToWorldSpace(lp1)
            local wp2 = originCF:PointToWorldSpace(lp2)
            local wp3 = originCF:PointToWorldSpace(lp3)

            if OBJ_RENDERMODE == "wireframe" then
                DrawWireframe(wp1, wp2, wp3, col)
            else
                DrawFilled(wp1, wp2, wp3, col)
            end
            rendered = rendered + 1

            if rendered % 20 == 0 then
                objStatus.Text = string.format(
                    "📦 %d / %d треуг. (%.0f%%)",
                    rendered, totalTris, rendered/totalTris*100
                )
                task.wait()
            end
        end

        local blockCount = rendered
        objStatus.Text = string.format(
            "✔ Preview готов! %d блоков из %d треуг.\nМасштаб: %.2f×\n%s",
            blockCount, totalTris, OBJ_SCALE,
            thenBuild and "⏳ Запускаем AutoBuild..." or "Нажми «Build» чтобы построить"
        )
        Notify("OBJ","Preview: "..blockCount.." блоков","success")
        objIsLoading = false

        if thenBuild then
            task.wait(0.5)
            objStatus.Text = "⏳ AutoBuild запущен..."
            local ok, msg = DoBuild()
            objStatus.Text = (ok and "✔ " or "✘ ")..msg
            Notify(ok and "AutoBuild" or "Ошибка", msg, ok and "success" or "error")
        end
    end)
end

-- ─── Кнопки ──────────────────────────────────────────────────
local objLoadBtn = RowBtn("👁   OBJ → Preview (без постройки)", Color3.fromRGB(30,80,160))
objLoadBtn.MouseButton1Click:Connect(function() OBJLoadIntoPreview(false) end)

Spacer(4)

local objBuildBtn = RowBtn("🏗   OBJ → Preview + Build", Color3.fromRGB(80,50,180))
objBuildBtn.MouseButton1Click:Connect(function()
    local Bp = LP.Backpack
    local Ch = LP.Character or LP.CharacterAdded:Wait()
    local hasBuild = (Bp:FindFirstChild("BuildingTool") and Bp.BuildingTool:FindFirstChild("RF"))
        or (Ch:FindFirstChild("BuildingTool") and Ch.BuildingTool:FindFirstChild("RF"))
    local hasScale = (Bp:FindFirstChild("ScalingTool") and Bp.ScalingTool:FindFirstChild("RF"))
        or (Ch:FindFirstChild("ScalingTool") and Ch.ScalingTool:FindFirstChild("RF"))
    if not hasBuild then Notify("Ошибка","Нужен BuildingTool в рюкзаке!","error"); return end
    if not hasScale  then Notify("Ошибка","Нужен ScalingTool в рюкзаке!","error"); return end
    OBJLoadIntoPreview(true)
end)

Spacer(4)

local objClearBtn = RowBtn("✖   Очистить OBJ Preview", Color3.fromRGB(84,30,30))
objClearBtn.MouseButton1Click:Connect(function()
    for _, b in ipairs(objBlockList) do
        if b and b.Parent then b:Destroy() end
    end
    objBlockList = {}
    objStatus.Text = "OBJ Preview очищен"
    Notify("OBJ","Preview очищен","warn")
end)

