-- ─── PlaceBlock — клонирует шаблон и выставляет PPart ────────
local BLOCK_THICK   = 0.05

local function PlaceBlock(cf, size, col)
    if not OBJ_BLOCK_TEMPLATE then return nil end
    local clone = OBJ_BLOCK_TEMPLATE:Clone()
    local pp    = clone:FindFirstChild("PPart")
    if not pp then clone:Destroy(); return nil end
    pp.CFrame     = cf
    pp.Size       = Vector3.new(
        math.max(size.X, BLOCK_THICK),
        math.max(size.Y, BLOCK_THICK),
        math.max(size.Z, BLOCK_THICK)
    )
    pp.Color      = col
    if pp:IsA("Part") then pp.Shape = Enum.PartType.Block end
    pp.Anchored   = true
    pp.CanCollide = false
    pp.CastShadow = false
    local hp = clone:FindFirstChild("Health")
    if hp then hp.Value = "" end
    clone.Parent = AutoBuildPreview
    table.insert(objBlockList, clone)
    return clone
end

-- ─── WIREFRAME: 3 блока-линии на треугольник (рёбра) ─────────
local EDGE_W = 0.05
local function DrawWireframe(p1, p2, p3, col)
    local function edge(a, b)
        local len = (b-a).Magnitude
        if len < 0.001 then return end
        PlaceBlock(CFrame.new((a+b)*0.5, b), Vector3.new(EDGE_W, EDGE_W, len), col)
    end
    edge(p1, p2); edge(p2, p3); edge(p3, p1)
end

local FILL_STRIPS = 8

-- ─── FILLED: 3 суб-треугольника, полоски параллельны ребру ───
-- Треугольник делится на 3 через центроид.
-- Для каждого суб-треугольника (ребро → центроид) полоски идут
-- ВДОЛЬ ребра → на том ребре нет лестницы, нет зубьев.
local function DrawFilled(p1, p2, p3, col)
    local faceN = (p2-p1):Cross(p3-p1)
    local fNL   = faceN.Magnitude
    if fNL < 1e-6 then return end
    faceN = faceN / fNL

    local centroid = (p1+p2+p3) / 3

    local function fillSubTri(a, b)
        local edgeVec = b - a
        local edgeLen = edgeVec.Magnitude
        if edgeLen < 0.001 then return end
        local axisX = edgeVec / edgeLen

        -- Направление от середины ребра к центроиду, перпендикулярно ребру
        local midEdge = (a + b) * 0.5
        local toC     = centroid - midEdge
        local toCperp = toC - axisX * toC:Dot(axisX)
        local h       = toCperp.Magnitude
        if h < 0.001 then return end
        local axisY = toCperp / h

        local stripH = h / FILL_STRIPS

        local overlap = 1.0 / FILL_STRIPS  -- оверлап = 1 полоска шириной
        for i = 0, FILL_STRIPS - 1 do
            local sBot = i       / FILL_STRIPS
            local sMid = (i+0.5) / FILL_STRIPS
            -- Ширина = по нижнему краю + оверлап по диагонали
            local w = edgeLen * (1 - sBot) + edgeLen * overlap * 0.5
            if w < 0.001 then continue end
            -- Высота = чуть больше чем stripH чтобы перекрыть зазор
            local sh = stripH * 1.05
            local center = midEdge + axisY * (sMid * h)
            local cf = CFrame.fromMatrix(center, axisX, axisY, -faceN)
            PlaceBlock(cf, Vector3.new(w, sh, BLOCK_THICK), col)
        end
    end

    fillSubTri(p1, p2)
    fillSubTri(p2, p3)
    fillSubTri(p3, p1)
end

-- ─── Color helper ────────────────────────────────────────────
local _hue = 0
local function NextColor(mode, faceN, triIdx, total)
    if mode == "rainbow_golden" then
        _hue = (_hue + 0.618033988749895) % 1
        return Color3.fromHSV(_hue, 0.82, 0.95)
    elseif mode == "rainbow_linear" then
        return Color3.fromHSV(triIdx/math.max(total,1), 0.82, 0.95)
    elseif mode == "white"   then return Color3.new(1,1,1)
    elseif mode == "gray"    then return Color3.fromRGB(160,160,160)
    elseif mode == "dark"    then return Color3.fromRGB(40,40,50)
    elseif mode == "normals" then
        local n = faceN or Vector3.new(0,1,0)
        return Color3.new(math.clamp(n.X*.5+.5,0,1), math.clamp(n.Y*.5+.5,0,1), math.clamp(n.Z*.5+.5,0,1))
    end
    return Color3.new(1,1,1)
end

