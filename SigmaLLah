-- ============================================================
--   Encoding utilities (без изменений)
-- ============================================================

local R2D = 57.29577951308232

local function Fl(x, y) return math.floor((x * (10^y)) + 0.5) / (10^y) end
local function Str(x) return tostring(x):gsub(" ", "") end
local function Raw(x) local t = x:split(",") return tonumber(t[1]), tonumber(t[2]), tonumber(t[3]) end
local function GAngStr(cf) local X, Y, Z = cf:ToEulerAnglesXYZ() return Fl(X*R2D,5)..","..Fl(Y*R2D,5)..","..Fl(Z*R2D,5) end
local function AngStr(s) local t = s:split(",") return CFrame.Angles(math.rad(tonumber(t[1])), math.rad(tonumber(t[2])), math.rad(tonumber(t[3]))) end

local function GetTeamBlocks(teamStr)
    local team = (teamStr == "My Team") and tostring(LP.Team) or teamStr
    local out  = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if tostring(p.Team) == team then
            local f = workspace.Blocks:FindFirstChild(p.Name)
            if f then
                for _, b in ipairs(f:GetChildren()) do
                    if b:FindFirstChild("Health") then table.insert(out, b) end
                end
            end
        end
    end
    return out
end

local function Encode(blocks, zone)
    local t = {}
    for _, v in ipairs(blocks) do
        local pp = v:FindFirstChild("PPart")
        if not pp then continue end
        if not t[v.Name] then t[v.Name] = {} end
        local sp = zone.CFrame:ToObjectSpace(pp.CFrame)
        local bp = BuildingParts:FindFirstChild(v.Name)
        table.insert(t[v.Name], {
            Rotation     = GAngStr(sp),
            Position     = Str(sp.p),
            ShowShadow   = pp.CastShadow or true,
            CanCollide   = pp.CanCollide or true,
            Anchored     = true,
            Transparency = pp.Transparency > 0 and pp.Transparency or nil,
            Size  = v.Name:find("Block") and pp.Size ~= Vector3.new(2,2,2) and Str(pp.Size) or nil,
            Color = bp and pp.Color ~= bp.PPart.Color and Str(pp.Color) or nil,
        })
    end
    return HttpService:JSONEncode(t)
end

local function Decode(json, size)
    size = size or 1
    local t  = {}
    local ok = pcall(function() t = HttpService:JSONDecode(json) end)
    if not ok then return {} end
    for block, arr in next, t do
        if BuildingParts:FindFirstChild(block) then
            for i, v in next, arr do
                local c  = t[block][i]
                local px, py, pz = Raw(v.Position)
                c.Position = CFrame.new(Vector3.new(px, py, pz) * size)
                c.Rotation = AngStr(v.Rotation)
                if v.Color then
                    local r, g, b = Raw(v.Color)
                    c.Color = Color3.new(r, g, b)
                else c.Color = nil end
                if v.Size and v.Size ~= "2,2,2" then
                    local sx, sy, sz = Raw(v.Size)
                    c.Size = Vector3.new(sx, sy, sz) * size
                else c.Size = nil end
                t[block][i] = c
            end
        else t[block] = nil end
    end
    return t
end

-- ─── File helpers ───────────────────────────────────────────
local function GetBuildFiles()
    local out, seen = {}, {}
    local ok, list  = pcall(listfiles, SAVE_FOLDER.."/")
    if ok and list then
        for _, f in ipairs(list) do
            if f:sub(-6) == ".Build" then
                local name = f:match("([^/\\]+)%.Build$")
                if name and not seen[name] then
                    seen[name] = true
                    local sz = 0
                    local s, c = pcall(readfile, f)
                    if s and c then sz = #c end
                    local ss = sz < 1024 and sz.." B"
                        or sz < 1048576 and string.format("%.1fKB", sz/1024)
                        or string.format("%.1fMB", sz/1048576)
                    table.insert(out, {name=name, size=sz, sizeStr=ss, path=f})
                end
            end
        end
    end
    table.sort(out, function(a,b) return a.name:lower() < b.name:lower() end)
    return out
end

local function FindPath(name)
    local p = SAVE_FOLDER.."/"..name..".Build"
    if isfile(p) then return p end
    p = SAVE_FOLDER.."/"..name
    if isfile(p) then return p end
    return nil
end

-- ─── Preview / Save ─────────────────────────────────────────
local function ClearPreview()
    for _, c in ipairs(AutoBuildPreview:GetChildren()) do
        if c.Name ~= "BuildPreviewHighlight" then c:Destroy() end
    end
end

local function PreviewBuild(path, size)
    local info = Decode(readfile(path), size or 1)
    local plot = GetZone(selectedTeam) or GetZone("My Team")
    if not plot then return end
    for btype, tbl in pairs(info) do
        local bpModel = BuildingParts:FindFirstChild(btype)
        if not bpModel then continue end
        for _, b in pairs(tbl) do
            task.spawn(function()
                local cl = bpModel:Clone()
                if cl.PrimaryPart then
                    cl:SetPrimaryPartCFrame(plot.CFrame * (b.Position * b.Rotation))
                else
                    local pp2 = cl:FindFirstChild("PPart")
                    if pp2 then pp2.CFrame = plot.CFrame * (b.Position * b.Rotation) end
                end
                if cl:FindFirstChild("Health") then cl.Health.Value = "" end
                cl.Parent = AutoBuildPreview
                local pp = cl:FindFirstChild("PPart")
                if pp then
                    pp.Size         = b.Size or pp.Size
                    pp.Anchored     = true
                    pp.Transparency = 0
                    pp.CastShadow   = b.ShowShadow or false
                    pp.CanCollide   = b.CanCollide or false
                    if b.Color then
                        for _, v in pairs(cl:GetDescendants()) do
                            if v:IsA("BasePart") then v.Color = b.Color end
                        end
                    end
                end
            end)
        end
    end
end

local function SaveBuild(name, teamStr)
    if not name or name:gsub(" ","") == "" then return false, "Enter a file name!" end
    local zone = GetZone(teamStr)
    if not zone then return false, "Team zone not found!" end
    local team   = (teamStr == "My Team") and tostring(LP.Team) or teamStr
    local blocks = GetTeamBlocks(team)
    if #blocks == 0 then return false, "No blocks found on your plot!" end
    local ok, err = pcall(writefile, SAVE_FOLDER.."/"..name..".Build", Encode(blocks, zone))
    return ok, ok and ("Saved: "..name..".Build") or ("Error: "..tostring(err))
end

-- ============================================================
--   DoBuild — matches original BetaInstantLoad exactly
-- ============================================================
local function DoBuild()
    local Bp = LP.Backpack
    local Ch = LP.Character or LP.CharacterAdded:Wait()

    local GetBuildingTool =
        (Bp:FindFirstChild("BuildingTool") and Bp.BuildingTool:FindFirstChild("RF")) or
        (Ch:FindFirstChild("BuildingTool") and Ch.BuildingTool:FindFirstChild("RF"))
    local GetScalingTool  =
        (Bp:FindFirstChild("ScalingTool")  and Bp.ScalingTool:FindFirstChild("RF"))  or
        (Ch:FindFirstChild("ScalingTool")  and Ch.ScalingTool:FindFirstChild("RF"))
    local GetPaintingTool =
        (Bp:FindFirstChild("PaintingTool") and Bp.PaintingTool:FindFirstChild("RF")) or
        (Ch:FindFirstChild("PaintingTool") and Ch.PaintingTool:FindFirstChild("RF"))

    if not GetBuildingTool then return false, "Equip BuildingTool first!" end
    if not GetScalingTool  then return false, "Equip ScalingTool first!"  end

    local PreviewModel = workspace:FindFirstChild("BuildPreview")
    if not PreviewModel or #PreviewModel:GetChildren() == 0 then
        return false, "Make a Preview first!"
    end

    local TeamOwner     = GetTeamOwner()
    local Data          = LP:FindFirstChild("Data")
    local TeamColorName = LP.TeamColor.Name
    local Zone          = workspace:FindFirstChild(TeamColorName .. "Zone")
    local Blocks        = workspace:FindFirstChild("Blocks")

    if not Zone   then return false, "Zone not found!" end
    if not Blocks then return false, "Blocks folder not found!" end

    local parts  = {}
    local colors = {}

    for _, child in pairs(PreviewModel:GetChildren()) do
        for _, pp in pairs(child:GetChildren()) do
            if pp.Name == "PPart" and pp.Parent then
                local parentName = child.Name
                local dataValue  = Data and Data:FindFirstChild(parentName)
                    and Data[parentName].Value or nil
                table.insert(parts, {
                    ParentName = parentName,
                    CFrame     = pp.CFrame,
                    Size       = pp.Size,
                    DataValue  = dataValue,
                })
                table.insert(colors, pp.Color)
            end
        end
    end

    if #parts == 0 then return false, "Preview is empty!" end

    for _, child in pairs(PreviewModel:GetChildren()) do
        task.spawn(function() child:Destroy() end)
    end

    -- Step 1: Place blocks high above zone
    for i, d in ipairs(parts) do
        task.spawn(function()
            local spawnCF = Zone.CFrame * CFrame.new(0, 1000 + i, 0)
            GetBuildingTool:InvokeServer(
                d.ParentName, d.DataValue, nil, nil, true, spawnCF, false
            )
        end)
    end

    -- Wait for blocks to appear
    local deadline = tick() + 30
    while tick() < deadline do
        local folder = Blocks:FindFirstChild(TeamOwner.Name)
        if folder and #folder:GetChildren() >= #parts then break end
        task.wait(0.3)
    end

    -- Step 2: Scale & collect paint queue
    local paintQueue  = {}
    local scaledCount = 0

    for i, d in ipairs(parts) do
        task.spawn(function()
            local ownerFolder = Blocks:FindFirstChild(TeamOwner.Name)
            local block       = ownerFolder and ownerFolder:FindFirstChild(d.ParentName)
            if block then
                local origName = block.Name
                block.Name = origName .. tostring(i)
                GetScalingTool:InvokeServer(block, d.Size, d.CFrame)
                table.insert(paintQueue, {block, colors[i]})
                task.defer(function() block.Name = origName end)
            end
            scaledCount = scaledCount + 1
        end)
    end

    local deadline2 = tick() + 30
    while scaledCount < #parts and tick() < deadline2 do task.wait(0.3) end

    -- Step 3: Paint for 25 seconds
    if GetPaintingTool and #paintQueue > 0 then
        local t0 = tick()
        while tick() - t0 < 25 do
            GetPaintingTool:InvokeServer(paintQueue)
            task.wait(0.5)
        end
    end

    return true, "Done! ("..#parts.." blocks)"
end

