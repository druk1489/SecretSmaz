-- ─── Find block template ─────────────────────────────────────
local OBJ_BLOCK_NAME, OBJ_BLOCK_TEMPLATE
local function FindBlockTemplate()
    -- Печатаем все доступные блоки чтобы понять структуру игры
    print("[LordHub OBJ] BuildingParts содержит:")
    for _, b in ipairs(BuildingParts:GetChildren()) do
        local pp = b:FindFirstChild("PPart")
        local shapeInfo = ""
        if pp then
            if pp:IsA("Part") then shapeInfo = " [Part shape="..tostring(pp.Shape).."]"
            elseif pp:IsA("MeshPart") then shapeInfo = " [MeshPart]"
            elseif pp:IsA("SpecialMesh") then shapeInfo = " [SpecialMesh]"
            else shapeInfo = " ["..pp.ClassName.."]" end
        else shapeInfo = " [нет PPart]" end
        print("  " .. b.Name .. shapeInfo)
    end

    -- Исключаем шарообразные/balloon формы, ищем кубические
    local preferred = {"MetalBlock","PlasticBlock","Block","WoodBlock","StoneBlock","GlassBlock"}
    for _, name in ipairs(preferred) do
        local b = BuildingParts:FindFirstChild(name)
        if b and b:FindFirstChild("PPart") then
            print("[LordHub OBJ] Используем шаблон: " .. name)
            return name, b
        end
    end
    -- Любой с PPart не-шар формой
    for _, b in ipairs(BuildingParts:GetChildren()) do
        local pp = b:FindFirstChild("PPart")
        if pp and pp:IsA("MeshPart") then
            print("[LordHub OBJ] Используем шаблон (MeshPart): " .. b.Name)
            return b.Name, b
        end
        if pp and pp:IsA("Part") and pp.Shape == Enum.PartType.Block then
            print("[LordHub OBJ] Используем шаблон (авто): " .. b.Name)
            return b.Name, b
        end
    end
    -- Крайний случай — любой с PPart
    for _, b in ipairs(BuildingParts:GetChildren()) do
        if b:FindFirstChild("PPart") then
            print("[LordHub OBJ] Используем шаблон (fallback): " .. b.Name)
            return b.Name, b
        end
    end
    return nil, nil
end
local ok_ft, err_ft = pcall(function()
